# =============================================================================
# ENTERPRISE SAAS INVOICE MANAGEMENT SYSTEM
# Backend Environment Variables — Example Template
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the `.env` file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------

# REQUIRED in production. Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-minimum-50-characters

# Set to False in production. Never run DEBUG=True in production.
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames. Add your domain and EC2 IP.
# Example: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,10.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------

# The name of your PostgreSQL database
POSTGRES_DB=invoice_manager

# PostgreSQL superuser username
POSTGRES_USER=saas_admin

# Strong password — minimum 24 characters with mixed case, digits, symbols
POSTGRES_PASSWORD=your-super-secret-db-password

# Hostname of the database server. Use 'db' when running in Docker Compose.
POSTGRES_HOST=db

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection URL used for Celery broker, cache, and Django Channels.
# Format: redis://:password@host:port/db_number
# Use 'redis://redis:6379/0' when running in Docker Compose.
REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------------------
# AWS S3 — PDF and File Storage
# -----------------------------------------------------------------------------

# AWS IAM user Access Key ID with S3 permissions only (principle of least privilege)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX

# AWS IAM user Secret Access Key. Keep this secret.
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# The S3 bucket name where invoice PDFs and uploads will be stored
AWS_STORAGE_BUCKET_NAME=your-invoice-bucket-name

# AWS region where your S3 bucket is located
# Examples: us-east-1, ap-south-1, eu-west-2
AWS_S3_REGION_NAME=us-east-1

# Set to True to use S3 for media files in production
# When True, requires django-storages[s3] package
USE_S3=False

# -----------------------------------------------------------------------------
# Brevo (Sendinblue) — Transactional Email Service
# -----------------------------------------------------------------------------

# Your Brevo API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-api-key-here

# The FROM email address for outgoing transactional emails
# Must be a verified sender in your Brevo account
BREVO_SENDER_EMAIL=invoices@yourdomain.com

# The display name shown in the FROM field
BREVO_SENDER_NAME=Your Company Invoice System

# -----------------------------------------------------------------------------
# JWT Authentication (SimpleJWT)
# -----------------------------------------------------------------------------

# Access token lifetime in minutes (recommended: 15 for production)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15

# Refresh token lifetime in days (recommended: 7)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# -----------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# Example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Security Settings (Production Only)
# -----------------------------------------------------------------------------

# Force HTTPS redirects. Set to True when behind SSL/TLS.
SECURE_SSL_REDIRECT=False

# HSTS duration in seconds. 31536000 = 1 year.
SECURE_HSTS_SECONDS=0

# -----------------------------------------------------------------------------
# Celery Worker Configuration
# -----------------------------------------------------------------------------

# Maximum number of tasks a worker can execute before being replaced
# Prevents memory leaks in long-running workers
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# -----------------------------------------------------------------------------
# Rate Limiting & Account Security (django-axes)
# -----------------------------------------------------------------------------

# Number of failed login attempts before account lockout
AXES_FAILURE_LIMIT=5

# Lockout duration in hours
AXES_COOLOFF_TIME=1

# -----------------------------------------------------------------------------
# File Upload Security
# -----------------------------------------------------------------------------

# Maximum file upload size in bytes (default: 10MB = 10485760)
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Maximum number of GET/POST parameters in a single request
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# -----------------------------------------------------------------------------
# OCR / AI Configuration
# -----------------------------------------------------------------------------

# If using Google Cloud Vision for OCR, provide the JSON key path
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-credentials.json

# OpenAI API key for AI smart draft feature (optional)
# OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# The public URL of your frontend application (used in email templates)
FRONTEND_URL=http://localhost:5173

# The public URL of your backend API
BACKEND_URL=http://localhost:8000

# Default timezone for the application
APP_TIMEZONE=UTC

# Default currency code
DEFAULT_CURRENCY=USD
