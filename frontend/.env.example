# =============================================================================
# ENTERPRISE SAAS INVOICE MANAGEMENT — FRONTEND ENVIRONMENT (Vite)
# =============================================================================
# Copy to `.env` and fill in your values.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# NEVER put secret keys here — this code ships to the client browser.
# =============================================================================

# The base URL of your Django backend API
# In development: http://localhost:8000/api/v1
# In production: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Display name for the application (shown in browser tab, emails, etc.)
VITE_APP_NAME=InvoiceManager

# Application version string (displayed in footer/about)
VITE_APP_VERSION=1.0.0
